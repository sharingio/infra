# Encrypt this file with
# sops -e --input-type dotenv .envrc > direnv.enc.yaml
# Decrypt .enc.envrc with
# sops -d --output-type dotenv direnv.enc.yaml > .envrc
# First draft of this, also looked at https://github.com/direnv/direnv/wiki/Sops
# Just needs to be a secrets `pwgen 12` is fine
export CODER_DB_PASSWORD=
export CODER_PG_CONNECTION_URL=postgres://postgres:$CODER_DB_PASSWORD@coder-db-postgres.coder.svc.cluster.local:5432/coder?sslmode=disabled
# We Could set a GITHUB Token for coder, but not for now
# https://github.com/settings/personal-access-tokens/new
# https://github.com/settings/personal-access-tokens/1633172
# Read and Write access to administration, code, and repository hooks
export GITHUB_TOKEN=
# https://coder.com/docs/v2/latest/admin/auth
# https://github.com/organizations/cloudnative-nz/settings/applications/new
# https://github.com/organizations/cloudnative-nz/settings/applications/2247328
export CODER_OAUTH2_GITHUB_CLIENT_ID=
export CODER_OAUTH2_GITHUB_CLIENT_SECRET=
# https://coder.com/docs/v2/latest/admin/git-providers
# https://github.com/organizations/cloudnative-nz/settings/apps/new
# https://github.com/organizations/cloudnative-nz/settings/apps/space-cloudnative-nz
# NOTE: this is NOT the App ID, use Client ID
export CODER_GITAUTH_0_CLIENT_ID=
# NOTE: this is Client Secret
export CODER_GITAUTH_0_CLIENT_SECRET=
# https://powerdns.ii.nz/domain/sharing.io
export SPACE_TLD=
# https://powerdns.ii.nz/admin/manage-user
# https://powerdns.ii.nz/admin/user/edit/sharing.io
export PDNS_USERNAME=
export PDNS_PASSWORD=
# https://powerdns.ii.nz/admin/manage-account
# https://powerdns.ii.nz/admin/account/edit/sharingio
# Bind this account to the Username
# https://powerdns.ii.nz/admin/manage-keys
# https://powerdns.ii.nz/admin/key/edit/6
# Bind this key to the Account
# https://powerdns.ii.nz/domain/setting/sharing.io/manage
# Ensure the Username and Account are tied the the domain
# Might be useful to set DynDNS 2 Settings to Allow on-demand creation of records
# ALL OF THE ABOVE HAS NO AFFECT ON RFC2136
# TSIG KEYS ARE A DIFFERENT INTERFACE / API
# We created a tsig key with DNS-UPDATE only for cloudnative.nz
# THIS HAS TO BE a RFC2136 TSIG KEY not a PowerDNS API key
# It seems to only be able to be created with the single admin root PDNS_API_KEY
export PDNS_TSIG_KEY=
# This is a Power DNS http API key
# Ideally scopped for only this domain
# Let's see if we can get by without it
export PDNS_API_KEY=
# I created a new project a key
# https://console.equinix.com/projects/82b5c425-8dd4-429e-ae0d-d32f265c63e4/general
export METAL_PROJECT_ID=
# https://console.equinix.com/projects/82b5c425-8dd4-429e-ae0d-d32f265c63e4/api-keys
export METAL_AUTH_TOKEN=
# OIDC with authentik deployed to sso.ii.nz
# https://sso.ii.nz/if/admin/#/administration/overview
# https://sso.ii.nz/if/user/#/library
# https://sso.ii.nz/if/admin/#/core/applications
# https://sso.ii.nz/if/admin/#/core/applications/sharing-io
# https://sso.ii.nz/if/admin/#/core/providers
# https://sso.ii.nz/if/admin/#/core/providers/3
export CODER_OIDC_CLIENT_ID=X
export CODER_OIDC_CLIENT_SECRET=X
# gitops GUI
export GITOPS_PASSWORD=
